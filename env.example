# Copy to .env for local dev (Railway uses the Variables tab instead).

# Password for the presenter + author areas. CHANGE THIS before your event.
ADMIN_PASSWORD=set-a-strong-password

# Where banks + uploaded images are stored. On Railway, mount a Volume here
# so your data survives redeploys.
DATA_DIR=/data

# Railway sets PORT automatically; only set this for local dev.
# PORT=3000
